[gcp]
# Proyecto GCP donde está el dataset de BigQuery
bq_project = "contigoapp-prod"

# Nombre del dataset creado en el Billing Export
bq_dataset = "billing_export_contigo"

# Nombre de la tabla generada por GCP (Billing Account ID con guiones → guiones bajos)
bq_table = "gcp_billing_export_v1_012B4F_B03B98_8DEA4E"

# Contenido completo del JSON del Service Account
credentials_json = '''
{
  "type": "service_account",
  "project_id": "contigoapp-prod",
  "private_key_id": "...",
  "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n",
  "client_email": "billing-dashboard-sa@contigoapp-prod.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}
'''
